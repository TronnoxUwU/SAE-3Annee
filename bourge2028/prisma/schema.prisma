// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Structure {
  id           Int            @id @default(autoincrement())
  nomStructure String?
  description  String?
  adresse     String?
  lienPhoto    String?
  dateCreation DateTime?
  // departementId Int?
  longitude    Float?
  latitude     Float?
  // relations
  departements Situer[]
  personnes    Appartenir[] // Appartenir (avec role)
  realisations Realisation[] // Réaliser
  cats         StructureCat[] // Avoir
}

model Situer {
  id            Int         @id @default(autoincrement())
  structure     Structure   @relation(fields: [structureId], references: [id])
  structureId   Int
  departement   Departement @relation(fields: [departementId], references: [id])
  departementId Int

  @@unique([structureId, departementId])
}

model Departement {
  id         Int      @id @default(autoincrement())
  nomDep     String
  structures Situer[]
  projets    Projet[]
}

model Personne {
  id           Int      @id @default(autoincrement())
  identifiant  String   @unique
  nom          String
  prenom       String
  email        String   @unique
  tel          String?
  password     String
  description  String?
  lienPhoto    String?
  dateCreation DateTime @default(now())
  role         String

  structures Appartenir[]
  redactions Rediger[]
}

model Appartenir {
  id          Int       @id @default(autoincrement())
  structure   Structure @relation(fields: [structureId], references: [id])
  structureId Int
  personne    Personne  @relation(fields: [personneId], references: [id])
  personneId  Int

  role   Role @relation(fields: [roleId], references: [id])
  roleId Int

  @@unique([structureId, personneId])
}

model Role {
  id  Int    @id @default(autoincrement())
  nom String @unique

  appartenir Appartenir[]
}

model Realisation {
  id        Int         @id @default(autoincrement())
  nom       String?
  structure Structure[]

  // Relations communes
  cats      RealisationCat[]
  rediger   Rediger[]
  // relations ISA 1:1
  projet    Projet?
  materiaux Materiau?
  technique Technique?
}

model Projet {
  id            Int         @id @default(autoincrement())
  nomProjet     String
  realisation   Realisation @relation(fields: [realisationId], references: [id])
  realisationId Int         @unique
  adresse       String?
  latitude     Float?
  longitude      Float?

  departement Departement[]
}

model Materiau {
  id            Int         @id @default(autoincrement())
  nomMateriau   String
  realisation   Realisation @relation(fields: [realisationId], references: [id])
  realisationId Int         @unique
}

model Technique {
  id            Int         @id @default(autoincrement())
  nomTechnique  String
  realisation   Realisation @relation(fields: [realisationId], references: [id])
  realisationId Int         @unique
}

model RealisationCat {
  id            Int         @id @default(autoincrement())
  realisation   Realisation @relation(fields: [realisationId], references: [id])
  realisationId Int
  categorie     Categorie   @relation(fields: [categorieId], references: [id])
  categorieId   Int

  @@unique([realisationId, categorieId])
}

model StructureCat {
  id          Int       @id @default(autoincrement())
  structure   Structure @relation(fields: [structureId], references: [id])
  structureId Int
  categorie   Categorie @relation(fields: [categorieId], references: [id])
  categorieId Int

  @@unique([structureId, categorieId])
}

model Categorie {
  id  Int    @id @default(autoincrement())
  nom String

  parentId Int?
  parent   Categorie?  @relation("CategorieToSouscategories", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children Categorie[] @relation("CategorieToSouscategories")

  realisations RealisationCat[]
  structures   StructureCat[]
  cartes       Carte[]
}

model Article {
  id         Int         @id @default(autoincrement())
  titre      String
  redactions Rediger[]
  composants Composant[]
  documents  Document[]
}

model Rediger {
  id            Int         @id @default(autoincrement())
  article       Article     @relation(fields: [articleId], references: [id])
  articleId     Int
  personne      Personne    @relation(fields: [personneId], references: [id])
  personneId    Int
  realisation   Realisation @relation(fields: [realisationId], references: [id])
  realisationId Int

  dateRedaction DateTime?
  dateModif     DateTime?

  @@unique([articleId, personneId])
}

/**
 * ----- DOCUMENTS liés à un ARTICLE via CONTENIR -----
 */
model Document {
  id   Int    @id @default(autoincrement())
  lien String

  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int
}

/**
 * ----- COMPOSANTS polymorphes liés à un ARTICLE -----
 */

model Composant {
  id                Int      @id @default(autoincrement())
  positionComposant Int
  type              String
  article           Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId         Int?

  // Relations ISA (1:1)
  paragraphe Paragraphe?
  titre      Titre?
  image      Image?
  caroussels Caroussel[]
}

/**
 * ----- Sous-types ISA -----
 */

model Paragraphe {
  id              Int       @id @default(autoincrement())
  texteParagraphe String?
  composant       Composant @relation(fields: [composantId], references: [id], onDelete: Cascade)
  composantId     Int       @unique
}

model Titre {
  id          Int       @id @default(autoincrement())
  niveauTitre Int?
  texteTitre  String?
  composant   Composant @relation(fields: [composantId], references: [id], onDelete: Cascade)
  composantId Int       @unique
}

model Image {
  id          Int       @id @default(autoincrement())
  lienImage   String?
  titreImage  String?
  copyright   String?
  composant   Composant @relation(fields: [composantId], references: [id], onDelete: Cascade)
  composantId Int       @unique

  caroussel   Caroussel? @relation(fields: [carousselId], references: [id], onDelete: Cascade)
  carousselId Int?
}

/**
 * ----- CAROUSSEL contenant plusieurs images -----
 */

model Caroussel {
  id             Int       @id @default(autoincrement())
  titreCaroussel String?
  composant      Composant @relation(fields: [composantId], references: [id], onDelete: Cascade)
  composantId    Int

  images Image[] // 2..N relation
}

model Analytics {
  id         Int      @id @default(autoincrement())
  page       String
  ipAddress  String? // need to be hashed
  userAgent  String? // type d’appareil
  dateVisite DateTime @default(now())
}

model Carte {
  id               Int     @id @default(autoincrement())
  titre            String?
  descriptionCarte String?
  lienCarte        String

  categories Categorie[]
}
